# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Retell.ai Configuration
NEXT_PUBLIC_RETELL_API_KEY=your-retell-api-key
RETELL_API_KEY_PRIVATE=your-retell-private-key
NEXT_PUBLIC_RETELL_AGENT_ID=your-agent-id

# OpenRouter API (for CS context LLM)
OPENROUTER_API_KEY=your-openrouter-key

# Voiceflow Webchat
NEXT_PUBLIC_VOICEFLOW_PROJECT_ID=your-voiceflow-project-id

# Resend Email
RESEND_API_KEY=your-resend-key
